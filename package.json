{
  "name": "anytime-markdown-monorepo",
  "version": "1.13.0",
  "license": "MIT",
  "private": true,
  "scripts": {
    "version:sync": "npm version --no-git-tag-version --workspaces",
    "spec:index": "node scripts/gen-spec-index.mjs /Shared/anytime-markdown-docs/spec 設計書 ja",
    "tech:index": "node scripts/gen-spec-index.mjs /Shared/anytime-markdown-docs/tech 技術ドキュメント ja",
    "proposal:index": "node scripts/gen-spec-index.mjs /Shared/anytime-markdown-docs/proposal 提案 ja",
    "review:index": "node scripts/gen-spec-index.mjs /Shared/anytime-markdown-docs/review レビュー ja",
    "check-skills": "node scripts/check-bundled-skills.mjs && node scripts/check-skill-refs.mjs && node scripts/check-shortcut-markers.mjs && npm run test:scripts",
    "test:scripts": "node --test scripts/*.test.mjs",
    "postinstall": "rm -rf node_modules/next-auth/node_modules/@auth",
    "lint": "eslint packages/markdown-viewer/src packages/web-app/src",
    "lint:fix": "eslint --fix packages/markdown-viewer/src packages/web-app/src",
    "prepare": "husky"
  },
  "workspaces": [
    "packages/markdown-viewer",
    "packages/markdown-rich",
    "packages/markdown-view",
    "packages/markdown-view-lite",
    "packages/markdown-react-islands",
