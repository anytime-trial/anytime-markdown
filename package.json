    "packages/markdown-core",
    "packages/spreadsheet-core",
    "packages/spreadsheet-viewer",
    "packages/chart-core",
    "packages/graph-react-islands",
    "packages/database-core",
    "packages/database-viewer",
    "packages/graph-core",
    "packages/ui-core",
    "packages/mcp-markdown",
    "packages/mcp-graph",
    "packages/cms-core",
    "packages/mcp-cms",
    "packages/mcp-cms-remote",
    "packages/vscode-common",
    "packages/vscode-markdown-extension",
    "packages/vscode-graph-extension",
    "packages/vscode-database-extension",
    "packages/vscode-sheet-extension",
    "packages/vscode-trail-extension",
    "packages/vscode-agent-extension",
    "packages/vscode-history-extension",
    "packages/vscode-extension-pack",
    "packages/web-app",
    "packages/trail-server",
    "packages/code-analysis-core",
    "packages/code-analysis-typescript",
    "packages/code-analysis-python",
    "packages/trail-core",
    "packages/trail-db",
    "packages/trail-viewer",
    "packages/graph-viewer",
    "packages/mindmap-viewer",
    "packages/mcp-trail",
    "packages/trace-core",
    "packages/trace-agent-node",
    "packages/trace-viewer",
    "packages/memory-core",
    "packages/doc-core",
    "packages/llm-core",
    "packages/ollama-core",
    "packages/agent-core",
    "packages/review-agent",
    "packages/markdown-eval-core"
  ],
  "overrides": {
    "serialize-javascript": "7.0.5",
    "diff": "8.0.3",
    "postcss": "8.5.10",
    "uuid": "^14.0.0",
    "next": "16.2.6",
    "@auth/core": "0.41.1",
    "next-auth": {
      "@auth/core": "0.41.1"
    },
    "handlebars": "4.7.9",
    "@xmldom/xmldom": "0.9.10",
    "brace-expansion": "1.1.13",
    "ignore": "7.0.5",
    "ws": "8.21.0",
    "markdown-it": "14.2.0",
    "linkify-it": "5.0.1",
    "dompurify": "3.4.11"
  },
  "devDependencies": {
    "@next/eslint-plugin-next": "^16.1.6",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "eslint-plugin-sonarjs": "4.1.0",
    "husky": "9.1.7",
    "raw-loader": "4.0.2",
    "typescript": "6.0.3",
    "typescript-eslint": "8.61.0"
  },
  "dependencies": {
    "@auth/core": "0.41.1",
    "@emotion/react": "11.14.0",
    "@emotion/styled": "11.14.0",
