[project]
name = "<project-name>-backend"
version = "0.1.0"
description = "FastAPI backend for <project-name>"
requires-python = ">=3.11"
dependencies = [
    "fastapi[standard]>=0.115,<0.116",
    "sqlalchemy>=2.0,<2.1",
    "alembic>=1.13,<1.14",
    "psycopg[binary]>=3.2,<3.3",
    "python-jose[cryptography]>=3.3,<3.4",
    "pydantic[email]>=2.9,<3.0",
    "pydantic-settings>=2.5,<3.0",
    "passlib[bcrypt]>=1.7,<2.0",
    "bcrypt<4.0",
    "uvicorn[standard]>=0.32,<0.33",
]

[dependency-groups]
dev = [
    "pytest>=8.3,<9.0",
    "pytest-asyncio>=0.24,<0.25",
    "httpx>=0.27,<0.28",
    "ruff>=0.7,<0.8",
]

[tool.ruff]
line-length = 100
target-version = "py311"

[tool.ruff.lint]
select = ["E", "F", "I", "B", "UP"]
ignore = ["B008"]  # FastAPI Depends() pattern requires function calls in defaults

[tool.ruff.lint.per-file-ignores]
"alembic/versions/*" = ["E501"]  # alembic autogenerate produces long lines

[tool.pytest.ini_options]
asyncio_mode = "auto"
pythonpath = ["."]
testpaths = ["tests"]
