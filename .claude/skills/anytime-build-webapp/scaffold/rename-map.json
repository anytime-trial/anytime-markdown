{
  "description": "anytime-lab クローン後の文字列置換マップ。<project-name> は Phase 4 で実プロジェクト名に置換される。in-place モードでは inPlaceExcludes のファイルを targets から除外する。validations の jq は jq 式、regex は 1 行完結の PCRE（GNU grep -P は複数行に一致しない）。",
  "replacements": [
    { "find": "anytime-lab", "replace": "<project-name>" }
  ],
  "targets": [
    "package.json",
    "docker-compose.yml",
    ".devcontainer/devcontainer.json",
    "README.md"
  ],
  "inPlaceExcludes": [
    ".devcontainer/devcontainer.json"
  ],
  "validations": [
    {
      "file": "package.json",
      "jq": ".name",
      "expected": "<project-name>"
    },
    {
      "file": "docker-compose.yml",
      "regex": "^\\s+<project-name>:",
      "expected": "match"
    }
  ]
}
