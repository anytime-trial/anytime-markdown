    "ui": 0.3,
    "packages": 0.5,
    "loop": 0.5,
    "persistence": 1,
    "schema": 1,
    "security": 1
  },
  "thresholds": {
    "machine": 0.2,
    "human": 0.6
  },
  "autoRouteEnabled": false,
  "minAutoRecords": 30,
  "levelGate": {
    "windowDays": 14,
    "missRateThreshold": 0.1,
    "minAccepted": 5
  },
  "fetchTimeoutMs": 10000,
  "repo": "anytime-markdown"
}
