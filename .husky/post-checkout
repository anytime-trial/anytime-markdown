set -eu

# ${1:-} 形式は必須。スクリプトの基点に --show-toplevel を使わない理由も
# .husky/reference-transaction のコメントを参照（worktree で外す）。
SCRIPT="$(dirname "$(git rev-parse --path-format=absolute --git-common-dir)")/scripts/git-activity-report.mjs"
[ -f "$SCRIPT" ] || exit 0

node "$SCRIPT" post-checkout "${1:-}" "${2:-}" "${3:-}" || true
