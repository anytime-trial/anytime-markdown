{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://anytime-markdown/graph-input.schema.json",
  "title": "GraphInput",
  "type": "object",
  "required": ["schemaVersion", "nodes", "edges"],
  "properties": {
    "schemaVersion": { "const": "1.0" },
    "name": { "type": "string" },
    "rootId": { "type": "string" },
    "layout": { "enum": ["radial", "tree-lr", "tree-tb"] },
    "nodes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "label"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "label": { "type": "string" },
          "type": { "enum": ["rect", "ellipse", "sticky", "text", "diamond", "parallelogram", "cylinder", "doc"] },
          "fill": { "type": "string" },
          "stroke": { "type": "string" },
          "strokeWidth": { "type": "number" },
          "fontColor": { "type": "string" },
          "doc": { "type": "string" },
          "metadata": { "type": "object" }
        }
      }
    },
    "edges": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["from", "to"],
        "properties": {
          "from": { "type": "string" },
          "to": { "type": "string" },
          "label": { "type": "string" },
          "weight": { "type": "number" }
        }
      }
    }
  }
}
