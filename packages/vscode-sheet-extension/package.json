{
  "name": "anytime-sheet",
  "displayName": "%displayName%",
  "description": "%description%",
  "version": "0.8.0",
  "license": "MIT",
  "publisher": "anytime-trial",
  "repository": {
    "type": "git",
    "url": "https://github.com/anytime-trial/anytime-markdown.git"
  },
  "engines": {
    "vscode": "^1.109.0"
  },
  "icon": "images/anytime-sheet-128.png",
  "categories": [
    "Visualization"
  ],
  "keywords": [
    "spreadsheet",
    "csv",
    "tsv",
    "sheet"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "customEditors": [
      {
        "viewType": "anytimeSheet",
        "displayName": "%customEditor.displayName%",
        "selector": [
          {
            "filenamePattern": "*.sheet"
          }
        ],
        "priority": "default"
      },
      {
        "viewType": "anytimeSheet.csv",
        "displayName": "%customEditor.displayName%",
        "selector": [
          {
            "filenamePattern": "*.csv"
          },
          {
            "filenamePattern": "*.tsv"
          }
        ],
        "priority": "option"
      }
    ],
    "commands": [
      {
        "command": "anytime-sheet.newSheet",
        "title": "%command.newSheet%"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "webpack",
    "watch": "webpack --watch",
    "package": "webpack --mode production --devtool hidden-source-map"
  },
  "devDependencies": {
    "@types/node": "22.x",
    "@types/vscode": "1.109.0",
    "ts-loader": "9.6.0",
    "typescript": "6.0.3",
    "webpack": "5.104.1",
    "webpack-cli": "6.0.1"
  },
  "dependencies": {
    "@anytime-markdown/spreadsheet-core": "*",
    "@anytime-markdown/spreadsheet-viewer": "*",
    "@anytime-markdown/vscode-common": "*"
  }
}
