{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "isolatedModules": true,
    "outDir": "out/webview",
    "paths": {
      "@anytime-markdown/graph-core": ["../graph-core/src/index.ts"],
      "@anytime-markdown/graph-core/*": ["../graph-core/*"],
      "@anytime-markdown/graph-viewer": ["../graph-viewer/src/index.ts"],
      "@anytime-markdown/graph-viewer/*": ["../graph-viewer/*"],
      "@anytime-markdown/vscode-common/webview": ["../vscode-common/src/webview/index.ts"]
    }
  },
  "include": [
    "src/webview/**/*",
    "../graph-core/src/**/*",
    "../graph-viewer/src/**/*",
    "../vscode-common/src/webview/**/*"
  ],
  "exclude": [
    "../graph-core/src/__tests__/**/*",
    "../graph-viewer/src/__tests__/**/*"
  ]
}
