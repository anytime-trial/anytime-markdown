{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2023", "DOM"],
    "composite": true,
    "rootDir": "src",
    "outDir": "dist",
    "isolatedModules": true,
    "declaration": true,
    "baseUrl": "."
  },
  "include": ["src/**/*"],
  "exclude": ["dist", "**/__tests__/**"]
}
