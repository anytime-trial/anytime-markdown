    "code": "---\nid: login\ntitle: ログイン\n---\n<div class=\"sm-screen\">\n  <div class=\"sm-header\">Anytime App</div>\n  <div class=\"sm-main\">\n    <div class=\"sm-card sm-col\" style=\"max-width:360px;margin:0 auto;\">\n      <p class=\"sm-heading\">ログイン</p>\n      <input class=\"sm-input\" placeholder=\"メールアドレス\" />\n      <input class=\"sm-input\" placeholder=\"パスワード\" />\n      <a class=\"sm-btn sm-btn-primary\" href=\"#home\">ログイン</a>\n      <a class=\"sm-btn\" href=\"#home\">パスワードを忘れた方</a>\n    </div>\n  </div>\n  <div class=\"sm-footer\">&copy; Anytime</div>\n</div>\n---\nid: home\ntitle: ホーム\n---\n<div class=\"sm-screen\">\n  <div class=\"sm-header\">ホーム</div>\n  <div class=\"sm-main sm-col\">\n    <p class=\"sm-heading\">ようこそ</p>\n    <span class=\"sm-text\" data-lines=\"2\" style=\"margin-bottom:18px;\"></span>\n    <a class=\"sm-btn\" href=\"#login\">ログアウト</a>\n  </div>\n</div>"
  },
  {
    "label": "Dashboard",
