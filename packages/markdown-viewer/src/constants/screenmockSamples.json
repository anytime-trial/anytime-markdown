    "icon": "stat",
    "enabled": true,
    "code": "---\nid: empty\ntitle: 空状態\n---\n<div class=\"sm-screen\">\n  <div class=\"sm-header\">プロジェクト</div>\n  <div class=\"sm-main sm-col\" style=\"align-items:center;text-align:center;\">\n    <div class=\"sm-img\" style=\"width:120px;\"></div>\n    <p class=\"sm-heading\">プロジェクトがありません</p>\n    <span class=\"sm-text\" data-lines=\"1\" style=\"width:280px;\"></span>\n    <a class=\"sm-btn sm-btn-primary\" href=\"#error\">新規作成</a>\n  </div>\n</div>\n---\nid: error\ntitle: エラー\n---\n<div class=\"sm-screen\">\n  <div class=\"sm-header\">プロジェクト</div>\n  <div class=\"sm-main sm-col\" style=\"align-items:center;text-align:center;\">\n    <span class=\"sm-badge\">エラー</span>\n    <p class=\"sm-heading\">読み込みに失敗しました</p>\n    <span class=\"sm-text\" data-lines=\"2\" style=\"width:280px;margin-bottom:18px;\"></span>\n    <a class=\"sm-btn sm-btn-primary\" href=\"#empty\">再試行</a>\n  </div>\n</div>"
  }
