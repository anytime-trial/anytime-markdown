{
	"extends": "../../tsconfig.base.json",
	"compilerOptions": {
		"module": "Node16",
		"composite": true,
		"rootDir": "src",
		"outDir": "dist",
		"types": ["node", "mocha"]
	},
	"include": [
		"src/**/*"
	],
	"exclude": [
		"src/webview/**/*",
		"src/noteGraph/__tests__/**/*",
		"src/claude/__tests__/**/*",
		"src/utils/__tests__/**/*",
		"src/docCore/__tests__/**/*"
	]
}
