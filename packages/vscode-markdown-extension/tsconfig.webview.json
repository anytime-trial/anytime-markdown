{
	"extends": "../../tsconfig.base.json",
	"compilerOptions": {
		"module": "ESNext",
		"moduleResolution": "bundler",
		"resolveJsonModule": true,
		"baseUrl": ".",
		"paths": {
			"@anytime-markdown/markdown-viewer": ["../markdown-viewer/src/index.ts"],
			"@anytime-markdown/markdown-viewer/*": ["../markdown-viewer/*"],
			"@anytime-markdown/markdown-rich": ["../markdown-rich/src/index.ts"],
			"@anytime-markdown/markdown-rich/*": ["../markdown-rich/*"],
			"@anytime-markdown/vscode-common/webview": ["../vscode-common/src/webview/index.ts"],
			"@anytime-markdown/markdown-core": ["../tiptap-vendor/core/src/index.ts"],
			"@anytime-markdown/markdown-core/*": ["../tiptap-vendor/core/src/*"],
			"@anytime-markdown/markdown-react": ["../tiptap-vendor/react/src/index.ts"],
			"@anytime-markdown/markdown-react/*": ["../tiptap-vendor/react/src/*"],
			"@anytime-markdown/markdown-pm/*": ["../tiptap-vendor/pm/*/index.ts"],
			"@anytime-markdown/markdown-starter-kit": ["../tiptap-vendor/starter-kit/src/index.ts"],
			"@anytime-markdown/markdown-extensions": ["../tiptap-vendor/extensions/src/index.ts"],
			"@anytime-markdown/markdown-extension-placeholder": ["../tiptap-vendor/_shims/extension-placeholder.ts"],
			"@anytime-markdown/markdown-extension-task-item": ["../tiptap-vendor/_shims/extension-task-item.ts"],
			"@anytime-markdown/markdown-extension-task-list": ["../tiptap-vendor/_shims/extension-task-list.ts"],
			"@anytime-markdown/markdown-extension-*": ["../tiptap-vendor/extension-*/src/index.ts"],
			"@anytime-markdown/markdown-md": ["../tiptap-vendor/tiptap-markdown"],
			"@/*": ["../markdown-viewer/src/*"]
		}
	},
	"include": [
		"src/webview/**/*",
		"../markdown-viewer/src/**/*",
		"../markdown-rich/src/**/*",
		"../vscode-common/src/webview/**/*"
	],
	"exclude": [
		"../markdown-viewer/src/__tests__/**/*",
		"../markdown-viewer/src/testUtils/**/*",
		"../markdown-rich/src/__tests__/**/*"
	]
}
