{
	"extends": "../../tsconfig.base.json",
	"compilerOptions": {
		"module": "ESNext",
		"moduleResolution": "bundler",
		"resolveJsonModule": true,
		"baseUrl": ".",
		"paths": {
			"@anytime-markdown/markdown-core": ["../markdown-core/src/index.ts"],
			"@anytime-markdown/markdown-core/*": ["../markdown-core/*"],
			"@anytime-markdown/markdown-rich": ["../markdown-rich/src/index.ts"],
			"@anytime-markdown/markdown-rich/*": ["../markdown-rich/*"],
			"@anytime-markdown/vscode-common/webview": ["../vscode-common/src/webview/index.ts"],
			"@tiptap/core": ["../tiptap-vendor/core/src/index.ts"],
			"@tiptap/core/*": ["../tiptap-vendor/core/src/*"],
			"@tiptap/react": ["../tiptap-vendor/react/src/index.ts"],
			"@tiptap/react/*": ["../tiptap-vendor/react/src/*"],
			"@tiptap/pm/*": ["../tiptap-vendor/pm/*/index.ts"],
			"@tiptap/starter-kit": ["../tiptap-vendor/starter-kit/src/index.ts"],
			"@tiptap/extensions": ["../tiptap-vendor/extensions/src/index.ts"],
			"@tiptap/extension-placeholder": ["../tiptap-vendor/_shims/extension-placeholder.ts"],
			"@tiptap/extension-task-item": ["../tiptap-vendor/_shims/extension-task-item.ts"],
			"@tiptap/extension-task-list": ["../tiptap-vendor/_shims/extension-task-list.ts"],
			"@tiptap/extension-*": ["../tiptap-vendor/extension-*/src/index.ts"],
			"tiptap-markdown": ["../tiptap-vendor/tiptap-markdown"],
			"@/*": ["../markdown-core/src/*"]
		}
	},
	"include": [
		"src/webview/**/*",
		"../markdown-core/src/**/*",
		"../markdown-rich/src/**/*",
		"../vscode-common/src/webview/**/*"
	],
	"exclude": [
		"../markdown-core/src/__tests__/**/*",
		"../markdown-core/src/testUtils/**/*",
		"../markdown-rich/src/__tests__/**/*"
	]
}
