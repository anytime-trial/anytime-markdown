{
  "name": "anytime-trail",
  "displayName": "%displayName%",
  "description": "%description%",
  "version": "0.19.0",
  "license": "MIT",
  "publisher": "anytime-trial",
  "repository": {
    "type": "git",
    "url": "https://github.com/anytime-trial/anytime-markdown.git"
  },
  "engines": {
    "vscode": "^1.109.0"
  },
  "categories": [
    "Visualization"
  ],
  "keywords": [
    "architecture",
    "trail",
    "dashboard",
    "analysis"
  ],
  "activationEvents": [
    "onView:anytimeTrail.dashboard"
  ],
  "icon": "images/anytime-control-256.png",
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "anytimeTrail",
          "title": "%viewsContainer.title%",
          "icon": "images/trail_activitybar_icon.svg"
        }
      ]
    },
    "views": {
      "anytimeTrail": [
        {
          "id": "anytimeTrail.aiNote",
          "name": "%view.aiNote%"
        },
        {
          "id": "anytimeTrail.dashboard",
          "name": "%view.dashboard%"
        },
        {
          "id": "anytimeTrail.pipelines",
          "name": "%view.pipelines%",
          "when": "anytimeTrail.analyzeAllEnabled"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "anytimeTrail.aiNote",
        "contents": "%viewsWelcome.aiNote%"
      },
      {
        "view": "anytimeTrail.dashboard",
        "contents": "%viewsWelcome.dashboard%"
      }
    ],
    "commands": [
      {
        "command": "anytime-trail.memory.rebuildIndex",
        "title": "%command.memory.rebuildIndex%",
        "category": "Anytime Trail"
      },
      {
        "command": "anytime-trail.analyzeAll.pause",
        "title": "%command.analyzeAll.pause%",
        "category": "Anytime Trail"
      },
      {
        "command": "anytime-trail.analyzeAll.resume",
        "title": "%command.analyzeAll.resume%",
        "category": "Anytime Trail"
      },
      {
        "command": "anytime-trail.analyzeAll.status",
        "title": "%command.analyzeAll.status%",
        "category": "Anytime Trail"
      },
      {
        "command": "anytime-trail.openAiNote",
        "title": "%command.openAiNote%",
        "category": "Anytime Trail",
        "icon": "$(note)"
      },
      {
        "command": "anytime-trail.openAiNoteSkill",
        "title": "%command.openAiNoteSkill%",
        "category": "Anytime Trail",
        "icon": "$(book)"
      },
      {
        "command": "anytime-trail.addAiNotePage",
        "title": "%command.addAiNotePage%",
        "category": "Anytime Trail",
        "icon": "$(add)"
      },
      {
        "command": "anytime-trail.deleteAiNotePage",
        "title": "%command.deleteAiNotePage%",
        "category": "Anytime Trail",
        "icon": "$(trash)"
      },
      {
        "command": "anytime-trail.openAiNotePage",
        "title": "%command.openAiNotePage%",
        "category": "Anytime Trail"
      },
      {
        "command": "anytime-trail.clearAiNote",
        "title": "%command.clearAiNote%",
        "category": "Anytime Trail",
        "icon": "$(trash)"
      },
      {
        "command": "anytime-trail.copyAiNotePath",
        "title": "%command.copyAiNotePath%",
        "category": "Anytime Trail",
        "icon": "$(clippy)"
      },
      {
        "command": "anytime-trail.openTrailViewer",
        "title": "%command.openTrailViewer%",
        "category": "Anytime Trail",
        "icon": "$(graph-line)"
      },
      {
        "command": "anytime-trail.analyzeAll",
        "title": "%command.analyzeAll%",
        "category": "Anytime Trail",
        "icon": "$(refresh)"
      },
      {
        "command": "anytime-trail.analyzeCurrentCode",
        "title": "%command.analyzeCurrentCode%",
        "category": "Anytime Trail",
        "icon": "$(symbol-class)"
      },
      {
        "command": "anytime-trail.analyzeCurrentCodePickTsconfig",
        "title": "%command.analyzeCurrentCodePickTsconfig%",
        "category": "Anytime Trail"
      },
      {
        "command": "anytime-trail.analyzeReleaseCode",
        "title": "%command.analyzeReleaseCode%",
        "category": "Anytime Trail"
      },
      {
        "command": "anytime-trail.runWithTrace",
        "title": "%command.runWithTrace%",
        "category": "Anytime Trail",
        "icon": "$(beaker)"
      },
      {
        "command": "anytime-trail.reinstallSkills",
        "title": "%command.reinstallSkills%",
        "category": "Anytime Trail"
      },
      {
        "command": "anytime-trail.registerMcpServer",
        "title": "%command.registerMcpServer%",
        "category": "Anytime Trail"
      },
      {
        "command": "anytime-trail.registerMcpToClaudeCode",
        "title": "%command.registerMcpToClaudeCode%",
        "category": "Anytime Trail"
      },
      {
        "command": "anytime-trail.killExtensionHost",
        "title": "%command.killExtensionHost%",
        "category": "Anytime Trail",
        "icon": "$(debug-stop)"
      }
    ],
    "mcpServerDefinitionProviders": [
      {
        "id": "anytime-trail.mcp",
        "label": "Anytime Trail"
      }
    ],
    "codeLensProviders": [
      {
        "language": "typescript",
        "scheme": "file"
      },
      {
        "language": "javascript",
        "scheme": "file"
      },
      {
        "language": "json",
        "scheme": "file"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "anytime-trail.openAiNoteSkill",
          "when": "view == anytimeTrail.aiNote",
          "group": "navigation@1"
        },
        {
          "command": "anytime-trail.addAiNotePage",
          "when": "view == anytimeTrail.aiNote",
          "group": "navigation@2"
        },
        {
          "command": "anytime-trail.clearAiNote",
          "when": "view == anytimeTrail.aiNote",
          "group": "navigation@3"
        },
        {
          "command": "anytime-trail.copyAiNotePath",
          "when": "view == anytimeTrail.aiNote",
          "group": "navigation@3"
        },
        {
          "command": "anytime-trail.analyzeCurrentCode",
          "when": "view == anytimeTrail.dashboard",
          "group": "navigation@1"
        },
        {
          "command": "anytime-trail.analyzeAll",
          "when": "view == anytimeTrail.pipelines",
          "group": "navigation@1"
        },
        {
          "command": "anytime-trail.killExtensionHost",
          "when": "view == anytimeTrail.dashboard",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "anytime-trail.deleteAiNotePage",
          "when": "view == anytimeTrail.aiNote && viewItem == noteItem",
          "group": "inline"
        }
      ]
    },
    "configuration": {
      "title": "Anytime Trail",
      "properties": {
        "anytimeTrail.workspace.path": {
          "type": "string",
          "default": "",
          "markdownDescription": "解析対象ワークスペースの絶対パス。Code Graph と C4 Model 両方の解析で使用される。空欄の場合は現在 VS Code で開いているワークスペースを使用する。"
        },
        "anytimeTrail.workspace.docsPath": {
          "type": "string",
          "default": "",
          "markdownDescription": "Absolute path to the documentation directory for C4 document links. When set, Markdown files with `c4Scope` frontmatter are indexed and shown in the C4 viewer."
        },
        "anytimeTrail.viewer.port": {
          "type": "number",
          "default": 19841,
          "description": "Port number for the Trail Viewer server"
        },
        "anytimeTrail.daemon.useExternalDaemon": {
          "type": "boolean",
          "default": false,
          "markdownDescription": "%config.daemon.useExternalDaemon%"
        },
        "anytimeTrail.database.storagePath": {
          "type": "string",
          "default": ".anytime/trail/db",
          "markdownDescription": "%config.database.storagePath%"
        },
        "anytimeTrail.analyzeAll.enabled": {
          "type": "boolean",
          "default": false,
          "markdownDescription": "%config.analyzeAll.enabled%"
        },
        "anytimeTrail.logs.minLevel": {
          "type": "string",
          "enum": ["debug", "info", "warn", "error"],
          "default": "debug",
          "markdownDescription": "%config.logs.minLevel%"
        }
      }
    }
  },
  "capabilities": {
    "untrustedWorkspaces": {
      "supported": "limited",
      "description": "Git operations and file system access require workspace trust.",
      "restrictedConfigurations": []
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run prepare-native && npm run package",
    "prepare-native": "node scripts/prepare-native-binding.cjs",
    "compile": "npm run prepare-native && webpack",
    "watch": "webpack --watch",
    "package": "npm run prepare-native && webpack --mode production --devtool hidden-source-map",
    "test": "jest --maxWorkers=1"
  },
  "dependencies": {
    "@anytime-markdown/agent-core": "*",
    "@anytime-markdown/graph-core": "*",
    "@anytime-markdown/memory-core": "*",
    "@anytime-markdown/mcp-trail": "*",
    "@anytime-markdown/trail-core": "*",
    "@anytime-markdown/trail-db": "*",
    "@anytime-markdown/trail-server": "*",
    "@anytime-markdown/vscode-common": "*",
    "@modelcontextprotocol/sdk": "1.27.1",
    "graphology": "0.26.0",
    "graphology-communities-louvain": "2.0.2",
    "graphology-layout": "0.6.1",
    "graphology-layout-forceatlas2": "0.10.1",
    "graphology-shortest-path": "2.1.0",
    "ignore": "7.0.5",
    "pg": "8.20.0",
    "typescript": "5.9.3",
    "ws": "8.18.2",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@emotion/react": "11.14.0",
    "@emotion/styled": "11.14.0",
    "@mui/icons-material": "7.3.8",
    "@mui/material": "7.3.8",
    "@types/jest": "29.5.14",
    "@types/node": "22.x",
    "@types/pg": "8.20.0",
    "@types/react": "19.1.6",
    "@types/react-dom": "19.1.6",
    "@types/vscode": "1.109.0",
    "@types/ws": "8.18.1",
    "copy-webpack-plugin": "14.0.0",
    "jest": "29.7.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "ts-jest": "29.3.4",
    "ts-loader": "9.5.4",
    "webpack": "5.104.1",
    "webpack-bundle-analyzer": "5.3.0",
    "webpack-cli": "6.0.1"
  }
}
