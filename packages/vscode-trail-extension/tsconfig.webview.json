{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "isolatedModules": true,
    "outDir": "out/webview",
    "paths": {
      "@anytime-markdown/graph-core": ["../graph-core/src/index.ts"],
      "@anytime-markdown/graph-core/*": ["../graph-core/*"],
      "@anytime-markdown/c4-kernel": ["../c4-kernel/src/index.ts"],
      "@anytime-markdown/c4-kernel/*": ["../c4-kernel/*"]
    }
  },
  "include": [
    "src/c4/webview/**/*",
    "../graph-core/src/**/*",
    "../c4-kernel/src/**/*"
  ],
  "exclude": [
    "../graph-core/src/__tests__/**/*",
    "../c4-kernel/src/__tests__/**/*"
  ]
}
