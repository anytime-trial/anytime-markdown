{
  "name": "@anytime-markdown/markdown-view",
  "version": "1.8.0",
  "license": "MIT",
  "description": "Readonly markdown viewer Web Component with diagram rendering (mermaid/katex/plantuml/math/chart/graph).",
  "type": "module",
  "main": "./dist/markdown-view.js",
  "module": "./dist/markdown-view.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
