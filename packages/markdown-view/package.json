    }
  },
  "files": ["dist"],
  "sideEffects": ["./dist/markdown-view.js"],
  "scripts": {
    "build": "node esbuild.mjs"
  },
  "dependencies": {
    "dompurify": "^3.0.0",
    "diff": "^8.0.3",
    "katex": "^0.16.0",
    "mathjs": "15.2.0",
    "mermaid": "^11.0.0",
    "plantuml-encoder": "^1.0.0",
    "jsxgraph": "^1.0.0",
    "plotly.js-gl3d-dist-min": "^3.0.0",
    "next-intl": "^3.0.0 || ^4.0.0"
  },
  "devDependencies": {
    "@anytime-markdown/markdown-rich": "*",
    "@anytime-markdown/markdown-viewer": "*",
    "esbuild": "0.27.3"
  },
  "publishConfig": {
    "access": "restricted"
