{
	"extends": "../../tsconfig.base.json",
	"compilerOptions": {
		"module": "ESNext",
		"moduleResolution": "bundler",
		"composite": true,
		"rootDir": "src",
		"outDir": "dist",
		"resolveJsonModule": true,
		"baseUrl": ".",
		"paths": {
			"@/*": ["./src/*"],
			"@anytime-markdown/markdown-core": ["../markdown-core/src/index.ts"],
			"@anytime-markdown/markdown-core/src/*": ["../markdown-core/src/*"],
			"@tiptap/core": ["@anytime-markdown/tiptap-vendor/core/src/index.ts"],
			"@tiptap/core/*": ["@anytime-markdown/tiptap-vendor/core/src/*"],
			"@tiptap/react": ["@anytime-markdown/tiptap-vendor/react/src/index.ts"],
			"@tiptap/react/*": ["@anytime-markdown/tiptap-vendor/react/src/*"],
			"@tiptap/pm/*": ["@anytime-markdown/tiptap-vendor/pm/*/index.ts"],
			"@tiptap/starter-kit": ["@anytime-markdown/tiptap-vendor/starter-kit/src/index.ts"],
			"@tiptap/extension-placeholder": ["@anytime-markdown/tiptap-vendor/_shims/extension-placeholder.ts"],
			"@tiptap/extension-task-item": ["@anytime-markdown/tiptap-vendor/_shims/extension-task-item.ts"],
			"@tiptap/extension-task-list": ["@anytime-markdown/tiptap-vendor/_shims/extension-task-list.ts"],
			"@tiptap/extension-*": ["@anytime-markdown/tiptap-vendor/extension-*/src/index.ts"],
			"tiptap-markdown": ["@anytime-markdown/tiptap-vendor/tiptap-markdown"]
		}
	},
	"include": ["src/**/*", "src/**/*.json"]
}
