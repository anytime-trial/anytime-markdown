{
	"extends": "../../tsconfig.base.json",
	"compilerOptions": {
		"module": "ESNext",
		"moduleResolution": "bundler",
		"composite": true,
		"rootDir": "src",
		"outDir": "dist",
		"resolveJsonModule": true,
		"baseUrl": ".",
		"paths": {
			"@/*": ["./src/*"],
			"@anytime-markdown/markdown-core": ["../markdown-core/src/index.ts"],
			"@anytime-markdown/markdown-core/src/*": ["../markdown-core/src/*"]
		}
	},
	"include": ["src/**/*", "src/**/*.json"]
}
