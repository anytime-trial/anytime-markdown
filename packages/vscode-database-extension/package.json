{
  "name": "anytime-database",
  "displayName": "%displayName%",
  "description": "%description%",
  "version": "0.1.0",
  "license": "MIT",
  "publisher": "anytime-trial",
  "repository": { "type": "git", "url": "https://github.com/anytime-trial/anytime-markdown.git" },
  "engines": { "vscode": "^1.109.0" },
  "icon": "images/anytime-database-128.png",
  "categories": ["Visualization"],
  "keywords": ["sqlite", "database", "viewer", "sql"],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "customEditors": [
      {
        "viewType": "anytimeDatabase.sqlite",
        "displayName": "%customEditor.displayName%",
        "selector": [
          { "filenamePattern": "*.db" },
          { "filenamePattern": "*.sqlite" },
          { "filenamePattern": "*.sqlite3" },
          { "filenamePattern": "*.db3" }
        ],
        "priority": "default"
      }
    ],
    "configuration": {
      "title": "%displayName%",
      "properties": {
        "anytimeDatabase.openMode": {
          "type": "string",
          "enum": ["readwrite", "readonly"],
          "default": "readwrite",
          "description": "%config.openMode.description%"
        },
        "anytimeDatabase.query.maxRows": {
          "type": "integer",
          "minimum": 1,
          "maximum": 1000000,
          "default": 1000,
          "description": "%config.queryMaxRows.description%"
        },
        "anytimeDatabase.query.warnThresholdMs": {
          "type": "integer",
          "minimum": 0,
          "default": 5000,
          "description": "%config.warnThresholdMs.description%"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "webpack",
    "watch": "webpack --watch",
    "package": "webpack --mode production --devtool hidden-source-map"
  },
  "devDependencies": {
    "@anytime-markdown/database-core": "*",
    "@anytime-markdown/database-viewer": "*",
    "@anytime-markdown/spreadsheet-core": "*",
    "@anytime-markdown/spreadsheet-viewer": "*",
    "@anytime-markdown/vscode-common": "*",
    "@types/better-sqlite3": "7.6.13",
    "@types/node": "22.x",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@types/vscode": "1.109.0",
    "copy-webpack-plugin": "12.0.2",
    "ts-loader": "9.5.4",
    "typescript": "5.9.3",
    "webpack": "5.104.1",
    "webpack-cli": "6.0.1"
  },
  "dependencies": {
    "@emotion/react": "11.14.0",
    "@emotion/styled": "11.14.0",
    "@mui/icons-material": "7.3.7",
    "@mui/material": "7.3.7",
    "better-sqlite3": "12.9.0",
    "next-intl": "4.9.1",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  }
}
