{
  "name": "anytime-database",
  "displayName": "%displayName%",
  "description": "%description%",
  "version": "0.2.5",
  "license": "MIT",
  "publisher": "anytime-trial",
  "repository": { "type": "git", "url": "https://github.com/anytime-trial/anytime-markdown.git" },
  "engines": { "vscode": "^1.109.0" },
  "icon": "images/anytime-database-128.png",
  "categories": ["Visualization"],
  "keywords": ["sqlite", "database", "viewer", "sql"],
  "activationEvents": [
    "onView:anytimeDatabase.database"
  ],
  "main": "./dist/extension.js",
  "l10n": "./l10n",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "anytimeDatabase",
          "title": "%viewsContainer.title%",
          "icon": "images/database-activitybar.svg"
        }
      ]
    },
    "views": {
      "anytimeDatabase": [
        {
          "id": "anytimeDatabase.database",
          "name": "%view.database%"
        }
      ]
    },
    "commands": [
      {
        "command": "anytime-database.syncToSupabase",
        "title": "%command.syncToSupabase%",
        "category": "Anytime Database"
      },
      {
        "command": "anytime-database.reconnectSupabase",
        "title": "%command.reconnectSupabase%",
        "category": "Anytime Database"
      },
      {
        "command": "anytimeDatabase.restoreBackup",
        "title": "%command.restoreBackup%",
        "category": "Anytime Database",
        "icon": "$(discard)"
      },
      {
        "command": "anytime-database.uploadBackupToS3",
        "title": "%command.uploadBackupToS3%",
        "category": "Anytime Database",
        "icon": "$(cloud-upload)"
      }
    ],
    "menus": {
      "view/item/context": [
        {
          "command": "anytime-database.syncToSupabase",
          "when": "view == anytimeDatabase.database && viewItem == supabaseDb",
          "group": "inline"
        },
        {
          "command": "anytime-database.reconnectSupabase",
          "when": "view == anytimeDatabase.database && viewItem == supabaseDb",
          "group": "inline"
        },
        {
          "command": "anytimeDatabase.restoreBackup",
          "when": "view == anytimeDatabase.database && viewItem == backupEntry",
          "group": "inline"
        },
        {
          "command": "anytime-database.uploadBackupToS3",
          "when": "view == anytimeDatabase.database && viewItem == backupEntryLatest",
          "group": "inline"
        }
      ]
    },
    "customEditors": [
      {
        "viewType": "anytimeDatabase.sqlite",
        "displayName": "%customEditor.displayName%",
        "selector": [
          { "filenamePattern": "*.db" },
          { "filenamePattern": "*.sqlite" },
          { "filenamePattern": "*.sqlite3" },
          { "filenamePattern": "*.db3" }
        ],
        "priority": "default"
      }
    ],
    "configuration": {
      "title": "%displayName%",
      "properties": {
        "anytimeDatabase.storagePath": {
          "type": "string",
          "default": ".anytime/trail/db",
          "markdownDescription": "%config.storagePath%"
        },
        "anytimeDatabase.openMode": {
          "type": "string",
          "enum": ["readwrite", "readonly"],
          "default": "readwrite",
          "description": "%config.openMode.description%"
        },
        "anytimeDatabase.query.maxRows": {
          "type": "integer",
          "minimum": 1,
          "maximum": 1000000,
          "default": 1000,
          "description": "%config.queryMaxRows.description%"
        },
        "anytimeDatabase.query.warnThresholdMs": {
          "type": "integer",
          "minimum": 0,
          "default": 5000,
          "description": "%config.warnThresholdMs.description%"
        },
        "anytimeDatabase.backup.generations": {
          "type": "number",
          "default": 1,
          "minimum": 1,
          "maximum": 10,
          "markdownDescription": "%config.backup.generations%"
        },
        "anytimeDatabase.backup.intervalDays": {
          "type": "number",
          "default": 1,
          "minimum": 0,
          "markdownDescription": "%config.backup.intervalDays%"
        },
        "anytimeDatabase.s3.bucket": {
          "type": "string",
          "default": "",
          "markdownDescription": "%config.s3.bucket.description%"
        },
        "anytimeDatabase.s3.region": {
          "type": "string",
          "default": "ap-northeast-1",
          "markdownDescription": "%config.s3.region.description%"
        },
        "anytimeDatabase.s3.prefix": {
          "type": "string",
          "default": "anytime-database-backups",
          "markdownDescription": "%config.s3.prefix.description%"
        },
        "anytimeDatabase.s3.accessKeyId": {
          "type": "string",
          "default": "",
          "markdownDescription": "%config.s3.accessKeyId.description%"
        },
        "anytimeDatabase.s3.secretAccessKey": {
          "type": "string",
          "default": "",
          "markdownDescription": "%config.s3.secretAccessKey.description%"
        },
        "anytimeTrail.remote.provider": {
          "type": "string",
          "enum": ["none", "supabase", "postgres"],
          "default": "none",
          "markdownDescription": "Remote sync provider for the trail database. `supabase` syncs the local `trail.db` to a Supabase project."
        },
        "anytimeTrail.remote.supabaseUrl": {
          "type": "string",
          "default": "",
          "markdownDescription": "Supabase project URL used when `#anytimeTrail.remote.provider#` is `supabase`."
        },
        "anytimeTrail.remote.supabaseServiceRoleKey": {
          "type": "string",
          "default": "",
          "markdownDescription": "Supabase **service_role** key used for sync writes (upsert/delete). This key bypasses Row-Level Security, so keep it secret: store it only in local/machine settings and never expose it in a browser bundle. RLS restricts the public anon key to read-only, so writes require this key."
        },
        "anytimeTrail.remote.supabaseAnonKey": {
          "type": "string",
          "default": "",
          "markdownDescription": "Deprecated. Previously used for sync writes; writes now require `#anytimeTrail.remote.supabaseServiceRoleKey#`. Retained for backward compatibility only."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "prepare-native": "node scripts/prepare-native-binding.cjs",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "compile": "npm run prepare-native && webpack",
    "watch": "webpack --watch",
    "package": "npm run clean && npm run prepare-native && webpack --mode production --devtool hidden-source-map",
    "test": "jest --maxWorkers=1"
  },
  "devDependencies": {
    "@anytime-markdown/database-core": "*",
    "@anytime-markdown/database-viewer": "*",
    "@anytime-markdown/spreadsheet-core": "*",
    "@anytime-markdown/spreadsheet-viewer": "*",
    "@anytime-markdown/vscode-common": "*",
    "@types/better-sqlite3": "7.6.13",
    "@types/jest": "30.0.0",
    "@types/node": "22.x",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@types/vscode": "1.109.0",
    "aws-sdk-client-mock": "4.1.0",
    "copy-webpack-plugin": "14.0.0",
    "jest": "30.2.0",
    "ts-jest": "29.4.6",
    "ts-loader": "9.5.4",
    "typescript": "5.9.3",
    "webpack": "5.104.1",
    "webpack-cli": "6.0.1"
  },
  "dependencies": {
    "@anytime-markdown/trail-core": "*",
    "@anytime-markdown/trail-db": "*",
    "@aws-sdk/client-s3": "3.1004.0",
    "better-sqlite3": "12.9.0",
    "next-intl": "4.12.0",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  }
}
