{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2023", "DOM", "DOM.Iterable", "webworker"],
    "types": ["@serwist/next/typings", "jest"],
    "plugins": [
      {
        "name": "next"
      }
    ],
    "incremental": true,
    "isolatedModules": true,
    "noEmit": true,
    "allowJs": true,
    "resolveJsonModule": true,
    "jsx": "preserve",
    "paths": {
      "@/*": ["../markdown-viewer/src/*"],
      "@anytime-markdown/markdown-viewer/src/*": ["../markdown-viewer/src/*"],
      "@anytime-markdown/markdown-viewer": ["../markdown-viewer/src/index.ts"],
      "@anytime-markdown/markdown-react-islands/src/*": ["../markdown-react-islands/src/*"],
      "@anytime-markdown/markdown-react-islands": ["../markdown-react-islands/src/index.ts"],
      "@anytime-markdown/markdown-engine": ["../markdown-engine/src/index.ts"],
      "@anytime-markdown/markdown-rich/src/*": ["../markdown-rich/src/*"],
      "@anytime-markdown/markdown-rich": ["../markdown-rich/src/index.ts"],
      "@anytime-markdown/graph-core": ["../graph-core/src/index.ts"],
      "@anytime-markdown/graph-core/*": ["../graph-core/src/*"],
      "@anytime-markdown/graph-viewer": ["../graph-viewer/src/index.ts"],
      "@anytime-markdown/graph-viewer/src/*": ["../graph-viewer/src/*"],
      "@anytime-markdown/mindmap-viewer": ["../mindmap-viewer/src/index.ts"],
      "@anytime-markdown/mindmap-viewer/*": ["../mindmap-viewer/src/*"],
      "@anytime-markdown/spreadsheet-viewer": ["../spreadsheet-viewer/src/index.ts"],
      "@anytime-markdown/trail-core/domain/metrics": ["../trail-core/src/domain/metrics/index.ts"],
      "@anytime-markdown/trail-viewer": ["../trail-viewer/src/index.ts"],
      "@anytime-markdown/trail-viewer/supabase": ["../trail-viewer/src/supabase/index.ts"],
      "@anytime-markdown/trace-core/c4Sequence": ["../trace-core/src/c4Sequence.ts"],
      "@anytime-markdown/markdown-core": ["../markdown-core/core/src/index.ts"],
      "@anytime-markdown/markdown-core/jsx-runtime": ["../markdown-core/core/src/jsx-runtime.ts"],
      "@anytime-markdown/markdown-core/jsx-dev-runtime": ["../markdown-core/core/src/jsx-runtime.ts"],
      "@anytime-markdown/markdown-starter-kit": ["../markdown-core/starter-kit/src/index.ts"],
      "@anytime-markdown/markdown-extensions": ["../markdown-core/extensions/src/index.ts"],
      "@anytime-markdown/markdown-md": ["../markdown-core/tiptap-markdown/index.js"],
      "@anytime-markdown/markdown-extension-placeholder": ["../markdown-core/_shims/extension-placeholder.ts"],
      "@anytime-markdown/markdown-extension-task-item": ["../markdown-core/_shims/extension-task-item.ts"],
      "@anytime-markdown/markdown-extension-task-list": ["../markdown-core/_shims/extension-task-list.ts"],
      "@anytime-markdown/markdown-pm/changeset": ["../markdown-core/pm/changeset/index.ts"],
      "@anytime-markdown/markdown-pm/collab": ["../markdown-core/pm/collab/index.ts"],
      "@anytime-markdown/markdown-pm/commands": ["../markdown-core/pm/commands/index.ts"],
      "@anytime-markdown/markdown-pm/dropcursor": ["../markdown-core/pm/dropcursor/index.ts"],
      "@anytime-markdown/markdown-pm/gapcursor": ["../markdown-core/pm/gapcursor/index.ts"],
      "@anytime-markdown/markdown-pm/history": ["../markdown-core/pm/history/index.ts"],
      "@anytime-markdown/markdown-pm/inputrules": ["../markdown-core/pm/inputrules/index.ts"],
      "@anytime-markdown/markdown-pm/keymap": ["../markdown-core/pm/keymap/index.ts"],
      "@anytime-markdown/markdown-pm/markdown": ["../markdown-core/pm/markdown/index.ts"],
      "@anytime-markdown/markdown-pm/menu": ["../markdown-core/pm/menu/index.ts"],
      "@anytime-markdown/markdown-pm/model": ["../markdown-core/pm/model/index.ts"],
      "@anytime-markdown/markdown-pm/schema-basic": ["../markdown-core/pm/schema-basic/index.ts"],
      "@anytime-markdown/markdown-pm/schema-list": ["../markdown-core/pm/schema-list/index.ts"],
      "@anytime-markdown/markdown-pm/state": ["../markdown-core/pm/state/index.ts"],
      "@anytime-markdown/markdown-pm/tables": ["../markdown-core/pm/tables/index.ts"],
      "@anytime-markdown/markdown-pm/trailing-node": ["../markdown-core/pm/trailing-node/index.ts"],
      "@anytime-markdown/markdown-pm/transform": ["../markdown-core/pm/transform/index.ts"],
      "@anytime-markdown/markdown-pm/view": ["../markdown-core/pm/view/index.ts"],
      "@anytime-markdown/markdown-extension-blockquote": ["../markdown-core/extension-blockquote/src/index.ts"],
      "@anytime-markdown/markdown-extension-bold": ["../markdown-core/extension-bold/src/index.ts"],
      "@anytime-markdown/markdown-extension-bubble-menu": ["../markdown-core/extension-bubble-menu/src/index.ts"],
      "@anytime-markdown/markdown-extension-bullet-list": ["../markdown-core/extension-bullet-list/src/index.ts"],
      "@anytime-markdown/markdown-extension-code": ["../markdown-core/extension-code/src/index.ts"],
      "@anytime-markdown/markdown-extension-code-block": ["../markdown-core/extension-code-block/src/index.ts"],
      "@anytime-markdown/markdown-extension-code-block-lowlight": ["../markdown-core/extension-code-block-lowlight/src/index.ts"],
      "@anytime-markdown/markdown-extension-document": ["../markdown-core/extension-document/src/index.ts"],
      "@anytime-markdown/markdown-extension-floating-menu": ["../markdown-core/extension-floating-menu/src/index.ts"],
      "@anytime-markdown/markdown-extension-hard-break": ["../markdown-core/extension-hard-break/src/index.ts"],
      "@anytime-markdown/markdown-extension-heading": ["../markdown-core/extension-heading/src/index.ts"],
      "@anytime-markdown/markdown-extension-highlight": ["../markdown-core/extension-highlight/src/index.ts"],
      "@anytime-markdown/markdown-extension-horizontal-rule": ["../markdown-core/extension-horizontal-rule/src/index.ts"],
      "@anytime-markdown/markdown-extension-image": ["../markdown-core/extension-image/src/index.ts"],
      "@anytime-markdown/markdown-extension-italic": ["../markdown-core/extension-italic/src/index.ts"],
      "@anytime-markdown/markdown-extension-link": ["../markdown-core/extension-link/src/index.ts"],
      "@anytime-markdown/markdown-extension-list": ["../markdown-core/extension-list/src/index.ts"],
      "@anytime-markdown/markdown-extension-ordered-list": ["../markdown-core/extension-ordered-list/src/index.ts"],
      "@anytime-markdown/markdown-extension-paragraph": ["../markdown-core/extension-paragraph/src/index.ts"],
      "@anytime-markdown/markdown-extension-strike": ["../markdown-core/extension-strike/src/index.ts"],
      "@anytime-markdown/markdown-extension-table": ["../markdown-core/extension-table/src/index.ts"],
      "@anytime-markdown/markdown-extension-text": ["../markdown-core/extension-text/src/index.ts"],
      "@anytime-markdown/markdown-extension-underline": ["../markdown-core/extension-underline/src/index.ts"]
    }
  },
  "include": [
    "src/**/*",
    "next-env.d.ts",
    ".next/types/**/*.ts",
    "../markdown-viewer/src/md.d.ts",
    "../markdown-viewer/src/types/vscode.d.ts",
    "../markdown-viewer/src/types/stylis.d.ts",
    "../markdown-react-islands/src/plotly-gl3d.d.ts"
  ],
  "exclude": [
    "node_modules",
    "public/sw.js"
  ]
}
