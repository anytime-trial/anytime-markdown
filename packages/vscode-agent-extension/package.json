{
  "name": "anytime-agent",
  "displayName": "%displayName%",
  "description": "%description%",
  "version": "1.7.0",
  "license": "MIT",
  "publisher": "anytime-trial",
  "repository": {
    "type": "git",
    "url": "https://github.com/anytime-trial/anytime-markdown.git"
  },
  "engines": {
    "vscode": "^1.109.0"
  },
  "icon": "images/camel_face.png",
  "categories": [
    "Other"
  ],
  "keywords": [
    "agent",
    "claude",
    "ollama",
    "llm"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onView:anytimeAgent.aiNote",
    "onView:anytimeAgent.mapping",
    "onView:anytimeAgent.worktreeOwnership",
    "onView:anytimeAgent.ollama"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "anytimeAgent",
          "title": "%viewsContainer.title%",
          "icon": "images/camel-activitybar.svg"
        }
      ]
    },
    "views": {
      "anytimeAgent": [
        {
          "id": "anytimeAgent.aiNote",
          "name": "%view.aiNote%"
        },
        {
          "id": "anytimeAgent.mapping",
          "name": "%view.mapping%"
        },
        {
          "id": "anytimeAgent.gitActivity",
          "name": "%view.gitActivity%"
        },
        {
          "id": "anytimeAgent.worktreeOwnership",
          "name": "%view.worktreeOwnership%"
        },
        {
          "id": "anytimeAgent.ollama",
          "name": "%view.ollama%"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "anytimeAgent.mapping",
        "contents": "%viewsWelcome.mapping%"
      },
      {
        "view": "anytimeAgent.aiNote",
        "contents": "%viewsWelcome.aiNote%"
      }
    ],
    "commands": [
      {
        "command": "anytime-agent.mapping.refresh",
        "title": "%command.mapping.refresh%",
        "icon": "$(refresh)",
        "category": "Anytime Agent"
      },
      {
        "command": "anytime-agent.mapping.cleanupStale",
        "title": "%command.mapping.cleanupStale%",
        "icon": "$(trash)",
        "category": "Anytime Agent"
      },
      {
        "command": "anytime-agent.mapping.toggleStale",
        "title": "%command.mapping.toggleStale%",
        "icon": "$(list-filter)",
        "category": "Anytime Agent"
      },
      {
        "command": "anytime-agent.mapping.handoffSession",
        "title": "%command.mapping.handoffSession%",
        "category": "Anytime Agent"
      },
      {
        "command": "anytime-agent.mapping.copySessionId",
        "title": "%command.mapping.copySessionId%",
        "category": "Anytime Agent"
      },
      {
        "command": "anytime-agent.mapping.deleteStatusFile",
        "title": "%command.mapping.deleteStatusFile%",
        "category": "Anytime Agent"
      },
      {
        "command": "anytime-agent.gitActivity.refresh",
        "title": "%command.gitActivity.refresh%",
        "icon": "$(refresh)",
        "category": "Anytime Agent"
      },
      {
        "command": "anytime-agent.gitActivity.toggleDestructiveOnly",
        "title": "%command.gitActivity.toggleDestructiveOnly%",
        "icon": "$(filter)",
        "category": "Anytime Agent"
      },
      {
        "command": "anytime-agent.gitActivity.setAttribution",
        "title": "%command.gitActivity.setAttribution%",
        "icon": "$(account)",
        "category": "Anytime Agent"
      },
      {
        "command": "anytime-agent.gitActivity.setDays",
        "title": "%command.gitActivity.setDays%",
        "icon": "$(calendar)",
        "category": "Anytime Agent"
      },
      {
        "command": "anytime-agent.gitActivity.copyCommand",
        "title": "%command.gitActivity.copyCommand%",
        "icon": "$(clippy)",
        "category": "Anytime Agent"
      },
      {
        "command": "anytime-agent.worktreeOwnership.refresh",
        "title": "%command.worktreeOwnership.refresh%",
        "icon": "$(refresh)",
        "category": "Anytime Agent"
      },
      {
        "command": "anytime-agent.worktreeOwnership.copyCommand",
        "title": "%command.worktreeOwnership.copyCommand%",
        "icon": "$(clippy)",
        "category": "Anytime Agent"
      },
      {
        "command": "anytime-agent.startOllama",
        "title": "%command.startOllama%",
        "category": "Anytime Agent",
        "icon": "$(play)"
      },
      {
        "command": "anytime-agent.openAiNote",
        "title": "%command.openAiNote%",
        "category": "Anytime Agent",
        "icon": "$(note)"
      },
      {
        "command": "anytime-agent.openAiNoteSkill",
        "title": "%command.openAiNoteSkill%",
        "category": "Anytime Agent",
        "icon": "$(book)"
      },
      {
        "command": "anytime-agent.addAiNotePage",
        "title": "%command.addAiNotePage%",
        "category": "Anytime Agent",
        "icon": "$(add)"
      },
      {
        "command": "anytime-agent.deleteAiNotePage",
        "title": "%command.deleteAiNotePage%",
        "category": "Anytime Agent",
        "icon": "$(trash)"
      },
      {
        "command": "anytime-agent.openAiNotePage",
        "title": "%command.openAiNotePage%",
        "category": "Anytime Agent"
      },
      {
        "command": "anytime-agent.clearAiNote",
        "title": "%command.clearAiNote%",
        "category": "Anytime Agent",
        "icon": "$(trash)"
      },
      {
        "command": "anytime-agent.copyAiNotePath",
        "title": "%command.copyAiNotePath%",
        "category": "Anytime Agent",
        "icon": "$(clippy)"
      },
      {
        "command": "anytime-agent.showWorkSnapshots",
        "title": "%command.showWorkSnapshots%",
        "category": "Anytime Agent"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "anytime-agent.mapping.refresh",
          "when": "view == anytimeAgent.mapping",
          "group": "navigation"
        },
        {
          "command": "anytime-agent.mapping.cleanupStale",
          "when": "view == anytimeAgent.mapping",
          "group": "navigation"
        },
        {
          "command": "anytime-agent.mapping.toggleStale",
          "when": "view == anytimeAgent.mapping && !anytimeAgent.mapping.filterActive",
          "group": "navigation",
          "icon": "$(filter)"
        },
        {
          "command": "anytime-agent.mapping.toggleStale",
          "when": "view == anytimeAgent.mapping && anytimeAgent.mapping.filterActive",
          "group": "navigation",
          "icon": "$(filter-filled)"
        },
        {
          "command": "anytime-agent.gitActivity.refresh",
          "when": "view == anytimeAgent.gitActivity",
          "group": "navigation@1"
        },
        {
          "command": "anytime-agent.gitActivity.toggleDestructiveOnly",
          "when": "view == anytimeAgent.gitActivity",
          "group": "navigation@2"
        },
        {
          "command": "anytime-agent.gitActivity.setAttribution",
          "when": "view == anytimeAgent.gitActivity",
          "group": "navigation@3"
        },
        {
          "command": "anytime-agent.gitActivity.setDays",
          "when": "view == anytimeAgent.gitActivity",
          "group": "navigation@4"
        },
        {
          "command": "anytime-agent.worktreeOwnership.refresh",
          "when": "view == anytimeAgent.worktreeOwnership",
          "group": "navigation@1"
        },
        {
          "command": "anytime-agent.startOllama",
          "when": "view == anytimeAgent.ollama && !anytime-agent.ollamaRunning",
          "group": "navigation"
        },
        {
          "command": "anytime-agent.openAiNoteSkill",
          "when": "view == anytimeAgent.aiNote",
          "group": "navigation@1"
        },
        {
          "command": "anytime-agent.addAiNotePage",
          "when": "view == anytimeAgent.aiNote",
          "group": "navigation@2"
        },
        {
          "command": "anytime-agent.clearAiNote",
          "when": "view == anytimeAgent.aiNote",
          "group": "navigation@3"
        },
        {
          "command": "anytime-agent.copyAiNotePath",
          "when": "view == anytimeAgent.aiNote",
          "group": "navigation@3"
        }
      ],
      "view/item/context": [
        {
          "command": "anytime-agent.mapping.handoffSession",
          "when": "view == anytimeAgent.mapping && viewItem =~ /^session/",
          "group": "1_open@2"
        },
        {
          "command": "anytime-agent.mapping.copySessionId",
          "when": "view == anytimeAgent.mapping && viewItem =~ /^(session|codexSession)/",
          "group": "2_copy@1"
        },
        {
          "command": "anytime-agent.mapping.deleteStatusFile",
          "when": "view == anytimeAgent.mapping && viewItem == session.stale",
          "group": "3_modify@1"
        },
        {
          "command": "anytime-agent.gitActivity.copyCommand",
          "when": "view == anytimeAgent.gitActivity && (viewItem == gitActivitySnapshot || viewItem == gitActivityDestructive)",
          "group": "2_copy@1"
        },
        {
          "command": "anytime-agent.worktreeOwnership.copyCommand",
          "when": "view == anytimeAgent.worktreeOwnership && viewItem == worktreeOwnershipRow",
          "group": "2_copy@1"
        },
        {
          "command": "anytime-agent.deleteAiNotePage",
          "when": "view == anytimeAgent.aiNote && viewItem == noteItem",
          "group": "inline"
        }
      ]
    },
    "configuration": {
      "title": "Anytime Agent",
      "properties": {
        "anytimeAgent.budget.dailyLimitTokens": {
          "type": [
            "number",
            "null"
          ],
          "default": null,
          "markdownDescription": "日次トークン上限。`null` で無効。"
        },
        "anytimeAgent.budget.sessionLimitTokens": {
          "type": [
            "number",
            "null"
          ],
          "default": null,
          "markdownDescription": "セッションあたりのトークン上限。`null` で無効。"
        },
        "anytimeAgent.budget.alertThresholdPct": {
          "type": "number",
          "default": 80,
          "minimum": 1,
          "maximum": 100,
          "markdownDescription": "上限に対する警告閾値（%）。"
        },
        "anytimeAgent.contextWarnTokens": {
          "type": "number",
          "default": 160000,
          "minimum": 1000,
          "markdownDescription": "セッションのコンテキストトークンがこの値を超えるとツリーに引き継ぎ推奨バッジ（⚠️）を表示する。"
        },
        "anytimeAgent.claudeMdGuidance": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "%configuration.claudeMdGuidance.markdownDescription%"
        },
        "anytimeAgent.tickets.directory": {
          "type": "string",
          "default": "",
          "scope": "resource",
          "markdownDescription": "%configuration.tickets.directory.markdownDescription%"
        },
        "anytimeAgent.showUsage": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "%configuration.showUsage.markdownDescription%"
        },
        "anytimeAgent.usageRefreshSeconds": {
          "type": "number",
          "default": 600,
          "minimum": 300,
          "markdownDescription": "%configuration.usageRefreshSeconds.markdownDescription%"
        },
        "anytimeAgent.sessionRetentionDays": {
          "type": "number",
          "default": 7,
          "minimum": 1,
          "markdownDescription": "未使用セッションを agent-status DB から自動削除するまでの保持日数。最終アクティビティからこの日数を超えたセッションを worker 起動時および 1 日ごとに削除する。Codex セッションのツリー表示もこの日数で絞り込む。"
        },
        "anytimeAgent.gitActivityRetentionDays": {
          "type": "number",
          "default": 90,
          "minimum": 7,
          "maximum": 365,
          "description": "%config.gitActivityRetentionDays.description%"
        },
        "anytimeAgent.workSnapshotIntervalMinutes": {
          "type": "number",
          "default": 15,
          "minimum": 0,
          "maximum": 60,
          "markdownDescription": "%config.workSnapshotIntervalMinutes.description%"
        },
        "anytimeAgent.workSnapshotRetentionDays": {
          "type": "number",
          "default": 7,
          "minimum": 1,
          "maximum": 90,
          "markdownDescription": "%config.workSnapshotRetentionDays.description%"
        },
        "anytimeAgent.showCodexSessions": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "Agent マッピングに Codex（OpenAI CLI）のセッションを「Codex」グループとして表示する。Codex は rollout ファイルの読み取り専用スキャンのため、最終アクティビティとコンテキストトークンのみ表示され、編集中ロック・コミット・引き継ぎは非対応。"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "webpack",
    "watch": "webpack --watch",
    "package": "webpack --mode production --devtool hidden-source-map",
    "test": "jest --maxWorkers=1"
  },
  "dependencies": {
    "@anytime-markdown/agent-core": "*",
    "@anytime-markdown/vscode-common": "*"
  },
  "devDependencies": {
    "@types/jest": "30.0.0",
    "@types/node": "22.15.21",
    "@types/vscode": "1.109.0",
    "jest": "30.2.0",
    "ts-jest": "29.4.11",
    "ts-loader": "9.6.0",
    "typescript": "6.0.3",
    "webpack": "5.104.1",
    "webpack-cli": "6.0.1"
  }
}
