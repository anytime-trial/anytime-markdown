{
	"extends": "../../tsconfig.base.json",
	"comment": "markdown-core から切り出した vendored React binding（@tiptap/react）。consumer から composite 参照され、相対 paths 解決時の rootDir 制約(TS6059)回避と第三者型エラー抑制を担う。strict は上流のゆるい設定に合わせ off。markdown-core/pm を project reference + paths で参照する。",
	"compilerOptions": {
		"module": "ESNext",
		"moduleResolution": "bundler",
		"composite": true,
		"rootDir": "src",
		"outDir": "dist",
		"declaration": true,
		"strict": false,
		"noImplicitAny": false,
		"skipLibCheck": true,
		"lib": ["ES2023", "DOM", "DOM.Iterable"],
		"baseUrl": ".",
		"paths": {
			"@anytime-markdown/markdown-react": ["./src/index.ts"],
			"@anytime-markdown/markdown-react/*": ["./src/*"],
			"@anytime-markdown/markdown-core": ["../markdown-core/core/src/index.ts"],
			"@anytime-markdown/markdown-core/*": ["../markdown-core/core/src/*"],
			"@anytime-markdown/markdown-pm/*": ["../markdown-core/pm/*/index.ts"],
			"@anytime-markdown/markdown-extensions": ["../markdown-core/extensions/src/index.ts"],
			"@anytime-markdown/markdown-extension-*": ["../markdown-core/extension-*/src/index.ts"]
		}
	},
	"references": [{ "path": "../markdown-core" }],
	"include": ["src/**/*"],
	"exclude": ["**/__tests__/**", "dist"]
}
