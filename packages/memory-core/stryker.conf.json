{
  "$schema": "./node_modules/@stryker-mutator/core/schema/stryker-schema.json",
  "_comment": "PoC scope: mutation-test the pure embedding helpers (cosine / codec) only. Widen `mutate` after the workflow is proven.",
  "packageManager": "npm",
  "testRunner": "jest",
  "jest": {
    "projectType": "custom",
    "configFile": "jest.stryker.config.js"
  },
  "mutate": ["src/embedding/**/*.ts"],
  "coverageAnalysis": "perTest",
  "tsconfigFile": "tsconfig.json",
  "checkers": [],
  "concurrency": 2,
  "reporters": ["html", "clear-text", "progress"],
  "htmlReporter": {
    "fileName": "reports/mutation/cosine-poc.html"
  },
  "thresholds": {
    "high": 90,
    "low": 70,
    "break": null
  }
}
